{{- /* OS detection: osRelease only exists on Linux, ID_LIKE may be absent, and
       chezmoi only strips double quotes from os-release values (Gentoo uses ID='gentoo'). */ -}}
{{- $osRelease := default (dict) (get .chezmoi "osRelease") -}}
{{- $osId := trimAll `"` (trimAll "'" (default "" (get $osRelease "id"))) -}}
{{- $isGentoo := or (eq $osId "gentoo") (contains "gentoo" (default "" (get $osRelease "idLike"))) -}}
{{- $isVoid := eq $osId "void" -}}
# Using fish_add_path instead of manually modifying PATH; it is idempotent
fish_add_path --global ~/bin
fish_add_path --global ~/.cargo/bin
fish_add_path --global ~/.local/bin
fish_add_path --global ~/.cabal/bin
fish_add_path --global ~/.ghcup/bin
fish_add_path --global ~/applications/texlive/2026/bin/x86_64-linux
fish_add_path --global ~/applications/cmdstan/bin
fish_add_path --global ~/applications/xbps/usr/bin

# Environment variables
set -gx EDITOR nvim
set -gx VISUAL nvim
set -gx BROWSER firefox{{ if eq .chassis_type "laptop" }}-bin{{ end }}
set -gx FZF_DEFAULT_COMMAND "fd --type file --color=always"

{{- if $isGentoo }}
# Clang/LLVM toolchain
set -gx CC clang
set -gx CXX clang++
set -gx CPP clang-cpp
set -gx FC flang
set -gx LD ld.lld
set -gx AR llvm-ar
set -gx NM llvm-nm
set -gx RANLIB llvm-ranlib
set -gx OBJCOPY llvm-objcopy
set -gx STRIP llvm-strip
set -gx OBJDUMP llvm-objdump
set -gx READELF llvm-readelf

set -gx CFLAGS "-march=native -O2 -flto=thin"
set -gx CXXFLAGS "-march=native -O2 -flto=thin"
set -gx LDFLAGS "-fuse-ld=lld -Wl,-O1 -Wl,--as-needed"
set -gx RUSTFLAGS "-C target-cpu=native -C opt-level=3"
set -gx MAKEFLAGS "--jobs" (nproc)
{{- end}}

if status --is-interactive
    # only interactive shells have a tty for gpg to prompt on
    set -gx GPG_TTY (tty)

    # All my aliases
    # Kept inside the interactive guard so fish scripts get the real commands
    alias sudo="run0"
    # Modern command replacements
    alias cat="bat --paging=never"
    alias ls="eza --long --header --git --color=auto --group-directories-first"
    alias find="fd"
    alias top="btop"
    alias grep="rg"
    alias vim="nvim"

    # System management
    alias off="sudo poweroff"
    alias cp="cp -v --reflink=auto"
    alias mv="mv -v"

    # Process management
    alias psa="ps aux"
    alias psg="ps aux | rg -i"

    # Helper utilities
    alias preview="fzf --preview 'bat --color=always {}'"
    alias weather="curl -4 wttr.in/Cape+Town"

    abbr --add scu "systemctl --user"
    abbr --add scus "systemctl --user status"
    abbr --add scs "systemctl status"

    # OS-specific package management
{{- if $isVoid }}
    abbr --add xup "sudo xbps-install -Su"
    abbr --add xrm "sudo xbps-remove -R"
    abbr --add xinstall "sudo xbps-install -S"
{{- end}}
{{- if $isGentoo }}
    abbr --add einstall "sudo emerge --ask --verbose"
    abbr --add eremove "sudo emerge --ask --depclean"
    abbr --add eupdate "sudo emerge --ask --verbose --quiet --newuse --update --deep @world"
    abbr --add edepclean "sudo emerge --ask --depclean"
    abbr --add esync "sudo eix-sync"
    abbr --add esearch "eix"
{{- end}}

    # Useful abbreviations
    # Git
    abbr --add g "git"
    abbr --add gst "git status"
    abbr --add gc "git commit"
    abbr --add gco "git checkout"
    abbr --add ga "git add"
    abbr --add gaa "git add --all"
    abbr --add gb "git branch"
    abbr --add gd "git diff"
    abbr --add gl "git log"
    abbr --add gp "git push"
    abbr --add gpf "git push --force-with-lease"
    abbr --add gpl "git pull"

    # Jujutsu
    abbr --add j "jj"
    abbr --add js "jj st"
    abbr --add jd "jj diff"
    abbr --add jl "jj log"
    abbr --add jn "jj new"
    abbr --add jds "jj describe"
    abbr --add jsq "jj squash"
    abbr --add jt "jj tug"
    abbr --add jgp "jj git push"
    abbr --add jgf "jj git fetch"

    # Chezmoi
    abbr --add cz "chezmoi"
    abbr --add cza "chezmoi apply"
    abbr --add czd "chezmoi diff"
    abbr --add cze "chezmoi edit"
    abbr --add czs "chezmoi status"

    function fish_greeting
      echo
      echo -e (uname -ro | awk '{print " \\\\e[1mOS: \\\\e[0;32m"$0"\\\\e[0m"}')
      echo -e (uname -n | awk '{print " \\\\e[1mHostname: \\\\e[0;32m"$0"\\\\e[0m"}')
    end

    # Completion scripts are generated into the autoload dir and refreshed
    # only when the binary is newer than the generated file, instead of being
    # sourced on every shell (gh + pixi alone cost ~170ms that way).
    # Local-only, not managed by chezmoi.
    set -l comp_dir ~/.config/fish/completions
    test -d $comp_dir; or mkdir -p $comp_dir
    if command -q gh; and not test $comp_dir/gh.fish -nt (command -v gh)
        gh completion --shell fish > $comp_dir/gh.fish
    end
    if command -q pixi; and not test $comp_dir/pixi.fish -nt (command -v pixi)
        pixi completion --shell fish > $comp_dir/pixi.fish
    end
    if command -q jj; and not test $comp_dir/jj.fish -nt (command -v jj)
        COMPLETE=fish jj > $comp_dir/jj.fish
    end

    # These are shell init hooks (prompt, cd hook, keybindings), not
    # completions -- they have to run in each shell and are cheap (~10ms each)
    if command -q zoxide
        zoxide init fish | source
    end

    if command -q starship
        starship init fish | source
    end

    if command -q atuin
        atuin init fish | source
    end
end
