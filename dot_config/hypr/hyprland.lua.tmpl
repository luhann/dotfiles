-- Hyprland Lua configuration
-- See https://wiki.hypr.land/Configuring/Start/
-- Converted from hyprlang (0.54) to Lua (0.55+)

--------------------
---- MONITORS ----
--------------------

-- See https://wiki.hypr.land/Configuring/Basics/Monitors/
{{- range .monitors }}
hl.monitor({
    output = {{ .output | quote }},
    mode = {{ .mode | quote }},
    position = {{ .position | quote }},
    scale = {{ if eq .scale "auto" }}"auto"{{ else }}{{ .scale }}{{ end }},
    {{- if index . "bitdepth" }}
    bitdepth = {{ .bitdepth }},
    {{- end }}
    {{- if index . "icc" }}
    icc = {{ .icc | quote }},
    {{- end }}
})
{{- end }}


---------------------
---- MY PROGRAMS ----
---------------------

local terminal = "alacritty"
local browser = "firefox{{ if eq .chassis_type "laptop" }}-bin{{ end }}"
local fileManager = "XDG_CURRENT_DESKTOP=kde dolphin"
local menu = "fuzzel"
local mainMod = "SUPER"

------------------------------
---- WORKSPACE RULES ---------
------------------------------
{{- $primary := (index .monitors 0).output -}}
{{- $secondary := "" -}}
{{- if gt (len .monitors) 1 -}}
{{-   $secondary = (index .monitors 1).output -}}
{{- end -}}
{{- if $primary }}

hl.workspace_rule({ workspace = 1, default_name = "main", monitor = {{ $primary | quote }}, default = true })
hl.workspace_rule({ workspace = 2, default_name = "alt", monitor = {{ $primary | quote }} })
hl.workspace_rule({ workspace = 3, default_name = "term", monitor = {{ $primary | quote }} })
hl.workspace_rule({ workspace = 4, default_name = "dev", monitor = {{ $primary | quote }} })
hl.workspace_rule({ workspace = 5, default_name = "misc", monitor = {{ $primary | quote }} })

{{- if $secondary }}
hl.workspace_rule({ workspace = 6, default_name = "alt_main", monitor = {{ $secondary | quote }}, default = true })
hl.workspace_rule({ workspace = 7, default_name = "alt_misc", monitor = {{ $secondary | quote }} })
hl.workspace_rule({ workspace = 8, default_name = "alt_term", monitor = {{ $secondary | quote }} })
hl.workspace_rule({ workspace = 9, default_name = "alt_dev", monitor = {{ $secondary | quote }} })
hl.workspace_rule({ workspace = 10, default_name = "alt_ext", monitor = {{ $secondary | quote }} })
{{- else }}
hl.workspace_rule({ workspace = 6, default_name = "alt_main", monitor = {{ $primary | quote }} })
hl.workspace_rule({ workspace = 7, default_name = "alt_misc", monitor = {{ $primary | quote }} })
hl.workspace_rule({ workspace = 8, default_name = "alt_term", monitor = {{ $primary | quote }} })
hl.workspace_rule({ workspace = 9, default_name = "alt_dev", monitor = {{ $primary | quote }} })
hl.workspace_rule({ workspace = 10, default_name = "alt_ext", monitor = {{ $primary | quote }} })
{{- end }}
{{- end }}

-------------------
---- AUTOSTART ----
-------------------

-- See https://wiki.hypr.land/Configuring/Basics/Autostart/
hl.on("hyprland.start", function()
    hl.exec_cmd("dbus-update-activation-environment --systemd --all")
    hl.exec_cmd("systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP")
    hl.exec_cmd("systemctl --user start hyprpolkitagent")
    hl.exec_cmd("hypridle")
    hl.exec_cmd("waybar")
    hl.exec_cmd("dunst")
    hl.exec_cmd("awww-daemon")
end)

-------------------------------
---- ENVIRONMENT VARIABLES ----
-------------------------------

-- See https://wiki.hypr.land/Configuring/Advanced-and-Cool/Environment-variables/
hl.env("TERMINAL", terminal)
hl.env("XCURSOR_SIZE", "24")
hl.env("XCURSOR_THEME", "phinger-cursors-light")
hl.env("HYPRCURSOR_SIZE", "24")
hl.env("QT_QPA_PLATFORM", "wayland")
hl.env("XDG_MENU_PREFIX", "plasma-")
{{- if .has_nvidia }}
hl.env("GBM_BACKEND", "nvidia-drm")
hl.env("__GLX_VENDOR_LIBRARY_NAME", "nvidia")
{{- end }}

-----------------------
---- LOOK AND FEEL ----
-----------------------

-- Refer to https://wiki.hypr.land/Configuring/Basics/Variables/
hl.config({
    render = {
        cm_enabled = true,
    },

    general = {
        gaps_in = 5,
        gaps_out = 10,
        border_size = 2,

        col = {
            active_border = { colors = { "{{ .colors.cyber_yellow }}80", "{{ .colors.cyber_teal }}80" }, angle = 90 },
            inactive_border = "{{ .colors.surface1 }}b3",
        },

        resize_on_border = true,
        allow_tearing = false,
        layout = "dwindle",
    },

    cursor = {
        inactive_timeout = 5,
    },

    decoration = {
        rounding = 6,
        active_opacity = 1.0,
        inactive_opacity = 0.9,
        fullscreen_opacity = 1.0,

        shadow = {
            enabled = {{ if eq .chassis_type "laptop" }}false{{ else }}true{{ end }},
            range = 4,
            render_power = 3,
            color = "#1a1a1aee",
        },

        blur = {
            enabled = {{ if eq .chassis_type "laptop" }}false{{ else }}true{{ end }},
            size = 3,
        },
    },

    animations = {
        enabled = true,
    },

    dwindle = {
        preserve_split = true,
    },

    master = {
        new_status = "slave",
    },

    misc = {
        force_default_wallpaper = -1,
        disable_hyprland_logo = true,
        enable_anr_dialog = false,
        vrr = 1,
    },

    debug = {
        disable_logs = true,
        vfr = true,
    },

    input = {
        scroll_factor = 1.95,
        natural_scroll = false,
        {{- if ne .chassis_type "desktop" }}
        kb_variant = "colemak_dh",
        kb_options = "caps:super,compose:rctrl",
        {{- end }}
    },
})

--------------------
---- ANIMATIONS ----
--------------------

-- See https://wiki.hypr.land/Configuring/Advanced-and-Cool/Animations/
hl.curve("easeOutQuint", { type = "bezier", points = { { 0.23, 1 }, { 0.32, 1 } } })
hl.curve("easeInOutCubic", { type = "bezier", points = { { 0.65, 0.05 }, { 0.36, 1 } } })
hl.curve("linear", { type = "bezier", points = { { 0, 0 }, { 1, 1 } } })
hl.curve("almostLinear", { type = "bezier", points = { { 0.5, 0.5 }, { 0.75, 1 } } })
hl.curve("quick", { type = "bezier", points = { { 0.15, 0 }, { 0.1, 1 } } })

hl.animation({ leaf = "global", enabled = true, speed = 10, bezier = "default" })
hl.animation({ leaf = "border", enabled = true, speed = 5.39, bezier = "easeOutQuint" })
hl.animation({ leaf = "windows", enabled = true, speed = 4.79, bezier = "easeOutQuint" })
hl.animation({ leaf = "windowsIn", enabled = true, speed = 4.1, bezier = "easeOutQuint", style = "popin 87%" })
hl.animation({ leaf = "windowsOut", enabled = true, speed = 1.49, bezier = "linear", style = "popin 87%" })
hl.animation({ leaf = "fadeIn", enabled = true, speed = 1.73, bezier = "almostLinear" })
hl.animation({ leaf = "fadeOut", enabled = true, speed = 1.46, bezier = "almostLinear" })
hl.animation({ leaf = "fade", enabled = true, speed = 3.03, bezier = "quick" })
hl.animation({ leaf = "layers", enabled = true, speed = 3.81, bezier = "easeOutQuint" })
hl.animation({ leaf = "layersIn", enabled = true, speed = 4, bezier = "easeOutQuint", style = "fade" })
hl.animation({ leaf = "layersOut", enabled = true, speed = 1.5, bezier = "linear", style = "fade" })
hl.animation({ leaf = "fadeLayersIn", enabled = true, speed = 1.79, bezier = "almostLinear" })
hl.animation({ leaf = "fadeLayersOut", enabled = true, speed = 1.39, bezier = "almostLinear" })
hl.animation({ leaf = "workspaces", enabled = true, speed = 1.94, bezier = "almostLinear", style = "fade" })
hl.animation({ leaf = "workspacesIn", enabled = true, speed = 1.21, bezier = "almostLinear", style = "fade" })
hl.animation({ leaf = "workspacesOut", enabled = true, speed = 1.94, bezier = "almostLinear", style = "fade" })

