-- Hyprland Lua configuration
-- See https://wiki.hypr.land/Configuring/Start/
-- Converted from hyprlang (0.54) to Lua (0.55+)

--------------------
---- MONITORS ----
--------------------

-- See https://wiki.hypr.land/Configuring/Basics/Monitors/
local monitors = {
{{- range .monitors }}
    {
        output = {{ .output | quote }},
        mode = {{ .mode | quote }},
        position = {{ .position | quote }},
        scale = {{ if eq .scale "auto" }}"auto"{{ else }}{{ .scale }}{{ end }},
        {{- if index . "bitdepth" }}
        bitdepth = {{ .bitdepth }},
        {{- end }}
        {{- if index . "icc" }}
        icc = {{ .icc | quote }},
        {{- end }}
    },
{{- end }}
}

for _, mon in ipairs(monitors) do
    hl.monitor(mon)
end


---------------------
---- MY PROGRAMS ----
---------------------

local terminal = "alacritty"
local browser = "firefox{{ if eq .chassis_type "laptop" }}-bin{{ end }}"
local fileManager = "nemo"
local menu = "rofi -show drun"
local mainMod = "SUPER"

------------------------------
---- WORKSPACE RULES ---------
------------------------------

if #monitors > 0 then
    local primary = monitors[1].output
    local secondaryOutput = monitors[2] and monitors[2].output or ""
    local hasSecondary = secondaryOutput ~= ""
    local secondary = hasSecondary and secondaryOutput or primary

    -- Looping by name keeps default_name in sync with the table key
    local workspaces = {
        main     = { id = 1,  monitor = primary },
        alt      = { id = 2,  monitor = primary },
        term     = { id = 3,  monitor = primary },
        dev      = { id = 4,  monitor = primary },
        misc     = { id = 5,  monitor = primary },
        alt_main = { id = 6,  monitor = secondary },
        alt_misc = { id = 7,  monitor = secondary },
        alt_term = { id = 8,  monitor = secondary },
        alt_dev  = { id = 9,  monitor = secondary },
        alt_ext  = { id = 10, monitor = secondary },
    }
    workspaces.main.default = true
    if hasSecondary then
        workspaces.alt_main.default = true
    end

    for name, ws in pairs(workspaces) do
        hl.workspace_rule({ workspace = ws.id, default_name = name, monitor = ws.monitor, default = ws.default })
    end
end

-------------------
---- AUTOSTART ----
-------------------

-- See https://wiki.hypr.land/Configuring/Basics/Autostart/
hl.on("hyprland.start", function()
    local autostart = {
        "hypridle",
        "waybar",
        "dunst",
        "awww-daemon",
        "alacritty --daemon",
        -- clipboard history + survive source window closing
        "wl-paste --type text --watch cliphist store",
        "wl-paste --type image --watch cliphist store",
        "wl-clip-persist --clipboard regular",
    }
    for _, cmd in ipairs(autostart) do
        hl.exec_cmd(cmd)
    end
end)

