sourceDir: "{{ .chezmoi.homeDir }}/dotfiles"
pager: delta

{{- /* Detect whether we're running in Codespaces. */ -}}
{{- $codespaces:= env "CODESPACES" | not | not -}}

{{- /* Determine chassis type across supported operating systems. */ -}}
{{- /* On VPS servers this will automatically detect them as "vm". */ -}}
{{- $chassis_type := "desktop" }}
{{- if eq .chezmoi.os "darwin" }}
{{-   if contains "MacBook" (output "system_profiler" "SPHardwareDataType") }}
{{-     $chassis_type = "laptop" }}
{{-   else }}
{{-     $chassis_type = "desktop" }}
{{-   end }}
{{- else if eq .chezmoi.os "linux" }}
{{-   $chassis_type = (output "hostnamectl" "--json=short" | mustFromJson).Chassis }}
{{- else if eq .chezmoi.os "windows" }}
{{-   $chassis_type = (output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "if ((Get-CimInstance -Class Win32_Battery | Measure-Object).Count -gt 0) { Write-Output 'laptop' } else { Write-Output 'desktop' }") | trim }}
{{- end }}

{{- /* Host-specific hardware flags. */ -}}
{{- $has_nvidia := false }}
{{- if eq .chezmoi.hostname "gestalt" }}{{-   $has_nvidia = true }}{{- end }}

{{- /* Resolve the CPU temperature sensor to its stable device path;
       /sys/class/hwmon numbering is not stable across boots. Empty if absent. */ -}}
{{- $hwmon_path := "" }}
{{- if eq .chezmoi.os "linux" }}
{{-   $cpu_sensor := "" }}
{{-   if eq $chassis_type "desktop" }}{{ $cpu_sensor = "k10temp" }}{{ else if eq $chassis_type "laptop" }}{{ $cpu_sensor = "coretemp" }}{{ end }}
{{-   if $cpu_sensor }}
{{-     $hwmon_path = output "sh" "-c" (print "grep -ls ^" $cpu_sensor " /sys/class/hwmon/hwmon*/name | head -n1 | xargs -r readlink -f | xargs -r dirname | xargs -r dirname") | trim }}
{{-   end }}
{{- end }}

{{- /* Prompt once for theme selection and load that palette. */ -}}
{{- $color_scheme := promptStringOnce . "color_scheme" "What color scheme to use" "patroclus" -}}
{{- $color_palette := (includeTemplate (print $color_scheme ".yaml") | fromYaml).colors }}

data:
  wm: hyprland
  chassis_type: {{ $chassis_type | quote }}
  codespaces: {{ $codespaces }}
  color_scheme: {{ $color_scheme | quote }}
  has_nvidia: {{ $has_nvidia }}
  hwmon_path: {{ $hwmon_path | quote }}

  colors:
    # Defaults not provided by the selected color palette.
    white: "#ffffff"
    black: "#000000"
{{- range $key, $val := $color_palette }}
    {{ $key }}: {{ $val | quote }}
{{- end }}

  # Monitor layout varies by detected chassis type.
  monitors:
{{- if eq $chassis_type "desktop" }}
    - output: "DP-1"
      mode: "2560x1440@165"
      position: "auto"
      scale: "auto"
      bitdepth: 10
      icc: "{{ .chezmoi.homeDir }}/desktop/dell_s2721.icc"
    - output: "DP-2"
      mode: "2560x1440@165"
      position: "auto-left"
      niri_x: -2560
      niri_y: 0
      scale: "auto"
      bitdepth: 10
      icc: "{{ .chezmoi.homeDir }}/desktop/dell_s2721.icc"
    - output: ""
      mode: "preferred"
      position: "auto"
      scale: "1"
{{- else if eq $chassis_type "laptop" }}
    - output: "eDP-1"
      mode: "preferred"
      position: "auto"
      scale: "auto"
      bitdepth: 10
    - output: ""
      mode: "preferred"
      position: "auto"
      scale: "1"
{{- else }}
    - output: ""
      mode: "preferred"
      position: "auto"
      scale: "1"
{{- end }}
