[user]
  email = luke@lukehannan.com
  name = Luke Hannan
  signingKey = CD004543DFCA0390
[gpg]
  program = /bin/gpg
[branch]
  sort = -committerdate
[column]
  ui = auto
[commit]
  gpgsign = true
  verbose = true
[core]
  autocrlf = input
  pager = delta
[credential]
  helper = cache
[delta]
  navigate = true
  side-by-side = true
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
[feature]
  manyFiles = true
[fetch]
  writeCommitGraph = true
[help]
  autocorrect = prompt
[init]
  defaultBranch = master
[interactive]
  diffFilter = delta --color-only
[maintenance]
  auto = true
  strategy = incremental
[merge]
  conflictStyle = zdiff3
[rebase]
  updateRefs = true
[rerere]
  enabled = true
  autoupdate = true
[tag]
  sort = version:refname
