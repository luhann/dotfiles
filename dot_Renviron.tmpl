{{- $make_jobs := "4" -}}
{{- if eq .chezmoi.os "linux" -}}
{{- $make_jobs = (output "nproc" | trim) -}}
{{- else if eq .chezmoi.os "darwin" -}}
{{- $make_jobs = (output "sysctl" "-n" "hw.logicalcpu" | trim) -}}
{{- end -}}
NOT_CRAN=true
DOWNLOAD_STATIC_LIBV8=1
MAKEFLAGS=-j{{ $make_jobs }}
R_LIBS_USER=~/rlibrary/
